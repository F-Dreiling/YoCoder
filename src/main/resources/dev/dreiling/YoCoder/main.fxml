<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="dev.dreiling.YoCoder.controller.MainController" styleClass="root-pane">

    <!-- ═══════════════════════════════════════════════════════════════ TITLE BAR -->
    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
                <Label text="🐾 YoCoder" styleClass="app-title"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Backend:" styleClass="label-dim"/>
                <Label fx:id="backendStatusLabel" text="Connecting..." styleClass="status-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Provider:" styleClass="label-dim"/>
                <ComboBox fx:id="providerCombo" styleClass="model-combo" onAction="#onProviderChanged"/>
                <Label text="Model:" styleClass="label-dim"/>
                <ComboBox fx:id="modelCombo" styleClass="model-combo"/>
                <Button text="⚙ Settings" styleClass="btn-ghost" onAction="#openSettings"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════════ MAIN -->
    <center>
        <SplitPane dividerPositions="0.22, 0.58">

            <!-- ══ LEFT: Project + file tree + context ════════════════════════ -->
            <VBox styleClass="panel-left" minWidth="200">

                <VBox styleClass="panel-section" spacing="6">
                    <Label text="PROJECT ROOT" styleClass="section-header"/>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <TextField fx:id="projectRootField" promptText="/path/to/project" HBox.hgrow="ALWAYS" styleClass="path-field"/>
                        <Button text="📂" styleClass="btn-icon" onAction="#browseProject"/>
                    </HBox>
                    <Button text="Scan Project" fx:id="scanBtn" styleClass="btn-primary" maxWidth="Infinity" onAction="#scanProject"/>
                </VBox>

                <Separator/>

                <!-- File tree -->
                <VBox VBox.vgrow="ALWAYS" styleClass="panel-section" spacing="6">
                    <Label text="FILES" styleClass="section-header"/>
                    <TextField fx:id="fileFilterField" promptText="Filter files..." styleClass="filter-field" onKeyReleased="#filterFiles"/>
                    <TreeView fx:id="fileTree" VBox.vgrow="ALWAYS" styleClass="file-tree"/>
                    <Label fx:id="fileCountLabel" text="" styleClass="label-dim small"/>
                </VBox>

                <Separator/>

                <!-- Context selection summary -->
                <VBox styleClass="panel-section" spacing="5">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="CONTEXT FILES" styleClass="section-header"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Clear" styleClass="btn-ghost-xs" onAction="#clearContextFiles"/>
                    </HBox>
                    <Label fx:id="contextCountLabel" text="None selected" styleClass="label-dim small" wrapText="true"/>
                    <Label text="Ctrl+click files to include as context" styleClass="label-hint" wrapText="true"/>
                </VBox>

                <Separator/>

                <!-- Quick prompts -->
                <VBox styleClass="panel-section" spacing="4">
                    <Label text="QUICK PROMPTS" styleClass="section-header"/>
                    <Button text="⚡  Optimize performance" styleClass="btn-preset" maxWidth="Infinity" onAction="#applyPreset"
                            userData="Optimize for performance. Identify and fix bottlenecks without changing the public API."/>
                    <Button text="🛡  Add error handling" styleClass="btn-preset" maxWidth="Infinity" onAction="#applyPreset"
                            userData="Add comprehensive error handling and input validation. Use meaningful error messages."/>
                    <Button text="📝  Add documentation" styleClass="btn-preset" maxWidth="Infinity" onAction="#applyPreset"
                            userData="Generate complete Javadoc/PHPDoc/JSDoc for all public methods, parameters, return values and exceptions. Keep all existing code identical."/>
                    <Button text="🧪  Add unit tests" styleClass="btn-preset" maxWidth="Infinity" onAction="#applyPreset"
                            userData="Generate comprehensive unit tests for this file covering happy path, edge cases, and error scenarios."/>
                    <Button text="⁉  Explain code" styleClass="btn-preset" maxWidth="Infinity" onAction="#applyPreset"
                            userData="Explain all methods, their purpose, parameters and return values. Be thorough but concise."/>
                </VBox>
            </VBox>

            <!-- ══ MIDDLE: Original file + prompt ════════════════════════════ -->
            <VBox styleClass="panel-mid" minWidth="300">

                <HBox styleClass="editor-header" alignment="CENTER_LEFT" spacing="8">
                    <Label text="ORIGINAL" styleClass="section-header"/>
                    <Label fx:id="selectedFileLabel" text="(no file selected)" styleClass="label-dim"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="fileSizeLabel" text="" styleClass="label-dim small"/>
                </HBox>

                <TextArea fx:id="originalCodeArea" VBox.vgrow="ALWAYS" editable="false" wrapText="false"
                          styleClass="code-area" promptText="Select a file from the tree..."/>

                <Separator/>

                <VBox styleClass="prompt-section" spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="REFACTORING INSTRUCTION" styleClass="section-header"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="charCountLabel" text="" styleClass="label-dim small"/>
                    </HBox>
                    <TextArea fx:id="promptArea" prefRowCount="4" wrapText="true" styleClass="prompt-area"
                              promptText="Describe what to refactor or ask. The AI will reply with explanations and ##FILE: sections where code changes are needed."/>
                    <HBox spacing="8" alignment="CENTER_RIGHT">
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Clear" styleClass="btn-ghost" onAction="#clearPrompt"/>
                        <Button fx:id="optimizeBtn" text="⚡  Send" styleClass="btn-optimize" onAction="#runOptimize"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ══ RIGHT: Output ══════════════════════════════════════════════ -->
            <VBox styleClass="panel-right" minWidth="300">

                <HBox styleClass="editor-header" alignment="CENTER_LEFT" spacing="8">
                    <Label text="OUTPUT" styleClass="section-header"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <StackPane VBox.vgrow="ALWAYS">
                    <WebView fx:id="outputWebView"/>

                    <VBox fx:id="thinkingOverlay" styleClass="thinking-overlay" alignment="CENTER" spacing="12"
                          visible="false" managed="false">
                        <ProgressIndicator fx:id="progressIndicator" maxWidth="48"/>
                        <Label fx:id="thinkingLabel" text="Thinking..." styleClass="thinking-label"/>
                        <Label fx:id="contextFilesLabel" text="" styleClass="label-dim small"/>
                    </VBox>
                </StackPane>

                <Separator/>

                <HBox styleClass="action-bar" spacing="8" alignment="CENTER_LEFT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="copyBtn" text="📋  Copy" styleClass="btn-ghost" onAction="#copyOutput" disable="true"/>
                    <Button fx:id="formatBtn" text="⇥  Format Code" styleClass="btn-format" onAction="#formatOutput" disable="true"/>
                </HBox>

            </VBox>

        </SplitPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════════ STATUS BAR -->
    <bottom>
        <HBox styleClass="status-bar" spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="Ready" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>

</BorderPane>
